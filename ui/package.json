{
  "name": "longue-vue-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "longue-vue CMDB web UI — audit views and curated asset metadata.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^3.2.4"
  }
}
